PROJECT_NAME="Kronos API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Database
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL="postgresql+asyncpg://kronos:kronos123@db:5432/kronos_db"

# Security
SECRET_KEY="replace_this_with_a_super_secret_key_in_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Redis (Socket.IO Pub/Sub)
REDIS_URL="redis://redis:6379/0"

# CORS
BACKEND_CORS_ORIGINS='["http://localhost:3000"]'
